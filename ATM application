package org.backingapplication;

public class ATM {
	
	public static  int total_transaction;
	static {
		total_transaction=0;
		System.out.println("ATM system Initated");
	}
	 
	public static void performTransaction(Bankaccount  account,String type,double amount) {
		 
		switch(type.toLowerCase()) {
		case "withdraw":
			account.withdraw(amount);
			total_transaction++;
			break;
	
		case"deposit":
			account.deposit(amount);
			total_transaction++;
			break;
	default:
		System.out.println("Inavild Transaction Type");
		
		}
	}
	public static void main(String[] args) {
		
	}

}
